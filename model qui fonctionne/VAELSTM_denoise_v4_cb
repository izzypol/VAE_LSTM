def plot_reconstruction_from_run_output(run_output, selected_idx=None):
    """
    Function that plots the reconstructed output values 
    """

    if selected_idx is None:
        selected_idx = 0
    if selected_idx < 0 or selected_idx >= len(run_output["test_wf"]):
        raise ValueError(
            f"selected_idx={selected_idx} out of range [0..{len(run_output['test_wf'])-1}]"
        )

    cfg = run_output["config"]
    model = run_output["model"]
    noisy = run_output["test_wf"][selected_idx]
    recon_mean = run_output["recon_means"][selected_idx]
    recon_std = run_output["recon_stds"][selected_idx]

    source_waveform_idx = int(run_output["test_meta"][selected_idx, 0])
    decay_id = int(run_output["test_meta"][selected_idx, 1])
    decay_label = (
        "first decay [450:750]" if decay_id == 0 else "second decay [1250:1550]"
    )
    print(
        f"Plotting test example {selected_idx} from source waveform {source_waveform_idx}, "
        f"decay {decay_id} ({decay_label})."
    )

    noisy_norm = run_output["test_wf_norm"][selected_idx]
    _, _, recon_samples_norm = mc_reconstruct_waveform(
        model,
        noisy_norm,
        mc_samples=cfg["mc_samples"],
        device=next(model.parameters()).device,
        return_samples=True,
    )

    waveform_min = run_output["test_wf_min"][selected_idx, 0]
    waveform_max = run_output["test_wf_max"][selected_idx, 0]
    waveform_range = (waveform_max - waveform_min).clamp_min(1e-6)
    recon_samples_repr = recon_samples_norm * waveform_range + waveform_min
    recon_samples_out = recon_samples_repr
    ci_lower = torch.quantile(recon_samples_out, 0.025, dim=0)
    ci_upper = torch.quantile(recon_samples_out, 0.975, dim=0)

    plot_reconstruction_with_uncertainty(
        noisy=noisy.cpu().numpy(),
        recon_mean=recon_mean.cpu().numpy(),
        recon_std=recon_std.cpu().numpy(),
        ci_lower=ci_lower.cpu().numpy(),
        ci_upper=ci_upper.cpu().numpy(),
    )


def plot_from_run_output(run_output, selected_idx=None):
    plot_training_losses_from_run_output(run_output)
    plot_reconstruction_from_run_output(run_output, selected_idx=selected_idx)


def run_model_comparison(base_config, model_variants=("lstm", "linear")):
    """
    Function that compares the lstm and linear models with the same base configuration 
    """

    if base_config.get("pipeline_mode", "train_and_evaluate") == "train_only":
        raise ValueError(
            "run_model_comparison requires evaluation outputs. "
            "Set pipeline_mode to 'train_and_evaluate' or 'evaluate_only'."
        )
    all_outputs = {}
    rows = []
    base_out = Path(base_config["output_dir"])
    base_out.mkdir(parents=True, exist_ok=True)

    for model_type in model_variants:
        cfg = dict(base_config)
        cfg["model_type"] = model_type
        cfg["output_dir"] = str(base_out / model_type)
        run_out = run_experiment(cfg)
        all_outputs[model_type] = run_out
        rows.append(
            {
                "model_type": model_type,
                "training_time_seconds": run_out["training_time_seconds"],
                "training_time_minutes": run_out["training_time_seconds"] / 60.0,
                "mae_mean": run_out["metrics"]["mae_mean"],
                "mae_std": run_out["metrics"]["mae_std"],
                "rmse_mean": run_out["metrics"]["rmse_mean"],
                "rmse_std": run_out["metrics"]["rmse_std"],
                "n2n_mse_mean": run_out["metrics"]["n2n_mean"],
                "n2n_mse_std": run_out["metrics"]["n2n_std"],
            }
        )

    comparison_df = pd.DataFrame(rows).sort_values("rmse_mean").reset_index(drop=True)
    comparison_df.to_csv(base_out / "comparison_metrics.csv", index=False)
    pvalues_df = pd.DataFrame()
    if base_config.get("pipeline_mode") != "train_only":
        pvalues_df = compute_paired_pvalues(all_outputs)
        if not pvalues_df.empty:
            pvalues_df.to_csv(base_out / "comparison_pvalues.csv", index=False)
            print(f"Saved paired p-values: {base_out / 'comparison_pvalues.csv'}")
            print(pvalues_df)
    else:
        print("Skipping p-values (no evaluation outputs in train_only mode).")

    print(f"Saved model comparison metrics: {base_out / 'comparison_metrics.csv'}")
    print(comparison_df)
    return all_outputs, comparison_df, pvalues_df


