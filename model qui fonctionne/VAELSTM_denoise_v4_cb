def compute_denoising_metrics(test_wf, recon_means):
    """
    Function that calculate the different metrics necessary for the other functions (mean and std)

    Arguments: 
    - test_wf: the test waveforms 
    - recon_means: the mean values of the reconstructed inputs 

    Returns: 
    - library of the different mean and std values calculated 
    """
    errors = recon_means - test_wf
    mae_per_waveform = torch.mean(torch.abs(errors), dim=1)
    rmse_per_waveform = torch.sqrt(torch.mean(errors**2, dim=1))

    return {
        "mae_per_waveform": mae_per_waveform,
        "rmse_per_waveform": rmse_per_waveform,
        "mae_mean": float(mae_per_waveform.mean().item()),
        "mae_std": float(mae_per_waveform.std().item()),
        "rmse_mean": float(rmse_per_waveform.mean().item()),
        "rmse_std": float(rmse_per_waveform.std().item()),
    }


def compute_neighbor2neighbor_metrics(test_wf, recon_means, test_meta):
    """Neighbor2Neighbor metric using paired decays from the same source waveform.

    For each source waveform with both decay_id 0 and 1 present:
      n2n = 0.5 * (MSE(|recon_0|, |noisy_1|) + MSE(|recon_1|, |noisy_0|))
    """
    n = len(test_wf)
    per_example = np.full(n, np.nan, dtype=float)

    source_ids = test_meta[:, 0].astype(int)
    decay_ids = test_meta[:, 1].astype(int)
    source_to_rows = {}
    for i, (src, dec) in enumerate(zip(source_ids, decay_ids)):
        if src not in source_to_rows:
            source_to_rows[src] = {}
        source_to_rows[src][int(dec)] = i

    per_source_vals = []
    for src, rows in source_to_rows.items():
        if 0 not in rows or 1 not in rows:
            continue
        i0, i1 = rows[0], rows[1]
        mse_01 = torch.mean(
            (torch.abs(recon_means[i0]) - torch.abs(test_wf[i1])) ** 2
        ).item()
        mse_10 = torch.mean(
            (torch.abs(recon_means[i1]) - torch.abs(test_wf[i0])) ** 2
        ).item()
        val = 0.5 * (mse_01 + mse_10)
        per_source_vals.append(val)
        per_example[i0] = val
        per_example[i1] = val

    per_source = np.asarray(per_source_vals, dtype=float)
    return {
        "n2n_per_example": per_example,
        "n2n_per_source": per_source,
        "n2n_mean": float(np.nanmean(per_source)) if per_source.size else float("nan"),
        "n2n_std": float(np.nanstd(per_source)) if per_source.size else float("nan"),
        "n2n_count_sources": int(per_source.size),
    }


def save_training_artifacts(
    output_dir,
    model,
    config,
    loss_total,
    loss_recon,
    loss_kld,
    training_time_seconds,
):
    """
    Function that savex the artifacts that might come up in training 
    """
    output_dir.mkdir(parents=True, exist_ok=True)
    checkpoint_path = output_dir / "model_weights.pt"
    torch.save(
        {"model_state_dict": model.state_dict(), "config": config}, checkpoint_path
    )
    pd.DataFrame(
        {
            "epoch": np.arange(1, len(loss_total) + 1),
            "loss_total": loss_total,
            "loss_recon": loss_recon,
            "loss_kld": loss_kld,
        }
    ).to_csv(output_dir / "training_history.csv", index=False)
    pd.DataFrame(
        [
            {
                "model_type": config["model_type"],
                "training_time_seconds": float(training_time_seconds),
                "training_time_minutes": float(training_time_seconds / 60.0),
            }
        ]
    ).to_csv(output_dir / "training_summary.csv", index=False)
    with open(output_dir / "train_config.json", "w", encoding="utf-8") as f:
        json.dump(config, f, indent=2)
    return checkpoint_path


