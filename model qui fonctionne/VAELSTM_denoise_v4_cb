def prepare_data(config):
    """
    Function that prepares the data from the csv 

    Arguments: 
    - config: variable that contains all the specifications that tell the code how to run the model

    Returns: 
    - library containing the necessary information pertaining to the extracted data 
    """

    device = "cuda" if torch.cuda.is_available() else "cpu"
    waveforms, waveform_meta = load_waveforms(
        config["csv_path"], max_examples=config["max_examples"]
    )

    # Grouped split by source waveform so both decays stay in the same set.
    source_ids = waveform_meta[:, 0].astype(int)
    unique_source_ids = np.unique(source_ids)
    train_source_ids, test_source_ids = train_test_split(
        unique_source_ids,
        test_size=config["test_size"],
        random_state=config["random_state"],
        shuffle=True,
    )
    train_mask = np.isin(source_ids, train_source_ids)
    test_mask = np.isin(source_ids, test_source_ids)

    waveforms_np = waveforms.numpy()
    train_wf_np = waveforms_np[train_mask]
    test_wf_np = waveforms_np[test_mask]
    train_meta = waveform_meta[train_mask]
    test_meta = waveform_meta[test_mask]

    train_wf = torch.tensor(train_wf_np, dtype=torch.float32)
    test_wf = torch.tensor(test_wf_np, dtype=torch.float32)
    train_wf_norm, _, _ = minmax_scale_per_waveform(train_wf)
    test_wf_norm, test_wf_min, test_wf_max = minmax_scale_per_waveform(test_wf)
    train_x = train_wf_norm.unsqueeze(-1)
    loader = DataLoader(
        TensorDataset(train_x), batch_size=config["batch_size"], shuffle=True
    )
    return {
        "device": device,
        "loader": loader,
        "test_wf": test_wf,
        "test_meta": test_meta,
        "test_wf_norm": test_wf_norm,
        "test_wf_min": test_wf_min,
        "test_wf_max": test_wf_max,
        "signal_length": int(train_wf.shape[1]),
    }


def build_model(config, device, signal_length):
    """
    Function that builds the model according to specifications

    Arguments: 
    - config: the specifications for the model
    - device: where the calculations will be done 
    - signal_length: length of the signal to be treated

    Returns: 
    - nothing but it builds the model
    """
    if config["model_type"] == "lstm":
        hidden_dim = config["lstm_hidden_dim"]
    else:
        hidden_dim = config["linear_hidden_dim"]
    return WindowVAE(
        signal_length=signal_length,
        hidden_dim=hidden_dim,
        latent_dim=config["latent_dim"],
        num_layers=config["num_layers"],
        model_type=config["model_type"],
    ).to(device)


def load_training_history(output_dir):
    """
    Function that saves the training history of the model 

    Arguments: 
    - output_dir: contains different training history variables 

    Returns: 
    - lists containing the training history values  
    """

    history_path = Path(output_dir) / "training_history.csv"
    if not history_path.exists():
        return [], [], []
    hist = pd.read_csv(history_path)
    return (
        hist["loss_total"].to_list(),
        hist["loss_recon"].to_list(),
        hist["loss_kld"].to_list(),
    )


def load_training_time_seconds(output_dir):
    """
    Function that records the time it takes to train the model 
    """

    summary_path = Path(output_dir) / "training_summary.csv"
    if not summary_path.exists():
        return 0.0
    summary = pd.read_csv(summary_path)
    if summary.empty or "training_time_seconds" not in summary.columns:
        return 0.0
    return float(summary.iloc[0]["training_time_seconds"])


def resolve_model_output_dir(config):
    """
    Unsure what this does 
    """
    base = Path(config["output_dir"])
    model_dir_name = str(config["model_type"])
    if base.name == model_dir_name:
        return base
    return base / model_dir_name


def resolve_checkpoint_path(config):
    """Resolve checkpoint path consistently with model-specific output folders."""
    model_output_dir = resolve_model_output_dir(config)
    model_ckpt = model_output_dir / "model_weights.pt"
    return model_ckpt


def run_training(config, prepared=None):
    """ 
    Function that runs the training of the model 
    """

    prepared = prepare_data(config) if prepared is None else prepared
    device = prepared["device"]
    print(f"Using device: {device}")
    model = build_model(config, device, signal_length=prepared["signal_length"])
    optimizer = torch.optim.Adam(model.parameters(), lr=config["lr"])
    train_t0 = time.perf_counter()
    loss_total, loss_recon, loss_kld = train_model(
        model,
        prepared["loader"],
        optimizer,
        num_epochs=config["num_epochs"],
        device=device,
    )
    train_time_seconds = time.perf_counter() - train_t0
    output_dir = resolve_model_output_dir(config)
    ckpt_saved = save_training_artifacts(
        output_dir=output_dir,
        model=model,
        config=config,
        loss_total=loss_total,
        loss_recon=loss_recon,
        loss_kld=loss_kld,
        training_time_seconds=train_time_seconds,
    )
    print(
        f"Training time ({config['model_type']}): {train_time_seconds:.2f} s "
        f"({train_time_seconds / 60.0:.2f} min)"
    )
    print(f"Saved training artifacts in: {output_dir}")
    print(f"Checkpoint: {ckpt_saved}")
    return {
        "model": model,
        "loss_total": loss_total,
        "loss_recon": loss_recon,
        "loss_kld": loss_kld,
        "training_time_seconds": float(train_time_seconds),
        "config": config,
        "output_dir": str(output_dir),
    }


def run_evaluation(config, model=None, prepared=None):
    """
    Function that runs the testing and evaluation of the model 
    """

    prepared = prepare_data(config) if prepared is None else prepared
    device = prepared["device"]
    print(f"Using device: {device}")
    if model is None:
        model = build_model(config, device, signal_length=prepared["signal_length"])
        ckpt_path = resolve_checkpoint_path(config)
        if not ckpt_path.exists():
            raise FileNotFoundError(f"checkpoint_path not found: {ckpt_path}")
        payload = torch.load(ckpt_path, map_location=device)
        model.load_state_dict(payload["model_state_dict"])
        print(f"Loaded checkpoint: {ckpt_path}")

    recon_means, recon_stds, recon_means_norm, recon_stds_norm, test_results_df = (
        predict_test_set(
            model=model,
            test_wf=prepared["test_wf"],
            test_wf_norm=prepared["test_wf_norm"],
            test_wf_min=prepared["test_wf_min"],
            test_wf_max=prepared["test_wf_max"],
            test_meta=prepared["test_meta"],
            mc_samples=config["mc_samples"],
            device=device,
        )
    )
    metrics = compute_denoising_metrics(prepared["test_wf_norm"], recon_means_norm)
    n2n_metrics = compute_neighbor2neighbor_metrics(
        prepared["test_wf_norm"], recon_means_norm, prepared["test_meta"]
    )
    test_results_df["mae"] = metrics["mae_per_waveform"].cpu().numpy()
    test_results_df["rmse"] = metrics["rmse_per_waveform"].cpu().numpy()
    test_results_df["neighbor2neighbor_mse"] = n2n_metrics["n2n_per_example"]

    output_dir = resolve_model_output_dir(config)
    training_time_seconds = load_training_time_seconds(output_dir)
    loss_total, loss_recon, loss_kld = load_training_history(output_dir)

    print(
        "Dataset reconstruction uncertainty std stats: "
        f"min={recon_stds.min().item():.6f}, max={recon_stds.max().item():.6f}, "
        f"mean={recon_stds.mean().item():.6f}"
    )
    print(
        f"Denoising metrics ({config['model_type']}): "
        f"MAE(norm)={metrics['mae_mean']:.6f}±{metrics['mae_std']:.6f}, "
        f"RMSE(norm)={metrics['rmse_mean']:.6f}±{metrics['rmse_std']:.6f}, "
        f"N2N-MSE(norm)={n2n_metrics['n2n_mean']:.6f}±{n2n_metrics['n2n_std']:.6f} "
        f"(sources={n2n_metrics['n2n_count_sources']})"
    )

    save_evaluation_artifacts(
        output_dir=output_dir,
        config=config,
        test_results_df=test_results_df,
        metrics_summary={
            "model_type": config["model_type"],
            "training_time_seconds": float(training_time_seconds),
            "training_time_minutes": float(training_time_seconds / 60.0),
            "mae_mean": metrics["mae_mean"],
            "mae_std": metrics["mae_std"],
            "rmse_mean": metrics["rmse_mean"],
            "rmse_std": metrics["rmse_std"],
            "n2n_mse_mean": n2n_metrics["n2n_mean"],
            "n2n_mse_std": n2n_metrics["n2n_std"],
            "n2n_count_sources": n2n_metrics["n2n_count_sources"],
        },
        recon_means=recon_means,
        recon_stds=recon_stds,
        test_wf=prepared["test_wf"],
    )
    print(f"Saved evaluation artifacts in: {output_dir}")

    return {
        "model": model,
        "test_wf": prepared["test_wf"],
        "test_meta": prepared["test_meta"],
        "test_wf_norm": prepared["test_wf_norm"],
        "test_wf_min": prepared["test_wf_min"],
        "test_wf_max": prepared["test_wf_max"],
        "test_results_df": test_results_df,
        "recon_means": recon_means,
        "recon_stds": recon_stds,
        "metrics": {**metrics, **n2n_metrics},
        "training_time_seconds": float(training_time_seconds),
        "config": config,
        "loss_total": loss_total,
        "loss_recon": loss_recon,
        "loss_kld": loss_kld,
        "output_dir": str(output_dir),
    }


def run_experiment(config):
    """Compatibility wrapper around separated training/evaluation pipelines."""
    mode = config.get("pipeline_mode", "train_and_evaluate")
    if mode == "train_only":
        return run_training(config)
    if mode == "evaluate_only":
        return run_evaluation(config)
    if mode == "train_and_evaluate":
        prepared = prepare_data(config)
        train_out = run_training(config, prepared=prepared)
        return run_evaluation(config, model=train_out["model"], prepared=prepared)
    raise ValueError(
        f"Unsupported pipeline_mode={mode}. Use train_only, evaluate_only, or train_and_evaluate."
    )


