import numpy as np
import pandas as pd
import torch
import torch.nn as nn
import torch.nn.functional as F
from sklearn.model_selection import train_test_split
from torch.utils.data import DataLoader, TensorDataset
import matplotlib.pyplot as plt


def load_waveforms(csv_path, max_examples=100, expected_length=1600):
    """Load full waveforms from CSV.

    Returns:
    - waveforms: tensor of shape (num_examples, seq_len)
    """
    raw = pd.read_csv(csv_path).transpose().values
    if max_examples is not None:
        raw = raw[:max_examples]

    if raw.shape[1] != expected_length:
        raise ValueError(
            f"Expected waveform length {expected_length}, got {raw.shape[1]}"
        )

    waveforms = torch.tensor(raw, dtype=torch.float32)
    return waveforms


def normalize_train_test(train_waveforms, test_waveforms):
    """Normalize using train-set statistics."""
    mean = train_waveforms.mean()
    std = train_waveforms.std().clamp_min(1e-6)
    train_norm = (train_waveforms - mean) / std
    test_norm = (test_waveforms - mean) / std
    return train_norm, test_norm, mean, std


class LSTMVAE(nn.Module):
    def __init__(
        self, seq_len, n_features=1, hidden_dim=64, latent_dim=8, num_layers=1
    ):
        super().__init__()
        self.seq_len = seq_len
        self.n_features = n_features
        self.hidden_dim = hidden_dim
        self.latent_dim = latent_dim
        self.num_layers = num_layers

        self.encoder = nn.LSTM(
            input_size=n_features,
            hidden_size=hidden_dim,
            num_layers=num_layers,
            batch_first=True,
        )
        self.to_mu = nn.Linear(hidden_dim, latent_dim)
        self.to_logvar = nn.Linear(hidden_dim, latent_dim)

        self.latent_to_hidden = nn.Linear(latent_dim, hidden_dim)
        self.latent_to_input = nn.Linear(latent_dim, n_features)
        self.decoder_input_proj = nn.Linear(n_features + latent_dim + 1, n_features)
        self.decoder = nn.LSTM(
            input_size=n_features,
            hidden_size=hidden_dim,
            num_layers=num_layers,
            batch_first=True,
        )
        self.to_output = nn.Linear(hidden_dim, n_features)

    def encode(self, x):
        _, (h_n, _) = self.encoder(x)
        h_last = h_n[-1]
        mu = self.to_mu(h_last)
        logvar = self.to_logvar(h_last)
        return mu, logvar

    def reparameterize(self, mu, logvar):
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        return mu + eps * std

    def decode(self, z, decoder_input=None):
        h0 = self.latent_to_hidden(z).unsqueeze(0).repeat(self.num_layers, 1, 1)
        c0 = torch.zeros_like(h0)

        batch_size = z.size(0)
        if decoder_input is None:
            base_input = torch.zeros(
                batch_size, self.seq_len, self.n_features, device=z.device
            )
        else:
            base_input = decoder_input

        z_repeated = z.unsqueeze(1).repeat(1, self.seq_len, 1)
        t = torch.linspace(0, 1, steps=self.seq_len, device=z.device).view(
            1, self.seq_len, 1
        )
        t = t.repeat(batch_size, 1, 1)
        decoder_features = torch.cat([base_input, z_repeated, t], dim=-1)
        dec_input = self.decoder_input_proj(decoder_features)

        dec_out, _ = self.decoder(dec_input, (h0, c0))
        recon = self.to_output(dec_out)
        return recon

    def forward(self, x, sample_latent=True, use_teacher_forcing=True):
        mu, logvar = self.encode(x)
        z = self.reparameterize(mu, logvar) if sample_latent else mu
        decoder_input = x if use_teacher_forcing else None
        recon = self.decode(z, decoder_input=decoder_input)
        return recon, mu, logvar


def softclip(input_tensor, min_value):
    return min_value + F.softplus(input_tensor - min_value)


def gaussian_nll(recon, log_sigma, target):
    const = 0.5 * torch.log(torch.tensor(2.0 * np.pi, device=target.device))
    return 0.5 * ((target - recon) / log_sigma.exp()) ** 2 + log_sigma + const


def vae_loss(recon, x, mu, logvar, min_log_sigma=-6.0):
    # Calibrated decoder: estimate a global residual noise scale and use Gaussian NLL.
    raw_log_sigma = ((x - recon) ** 2).mean().sqrt().log()
    log_sigma = softclip(raw_log_sigma, min_log_sigma)
    recon_loss = gaussian_nll(recon, log_sigma, x).sum(dim=(1, 2)).mean()
    kld = -0.5 * torch.mean(torch.sum(1 + logvar - mu.pow(2) - logvar.exp(), dim=1))
    total = recon_loss + kld
    return total, recon_loss, kld


def train_model(model, train_loader, optimizer, num_epochs=100, device="cpu"):
    loss_hist = []
    recon_hist = []
    kld_hist = []

    model.train()
    for epoch in range(num_epochs):
        total_loss = 0.0
        total_recon = 0.0
        total_kld = 0.0
        num_batches = 0

        for (batch_x,) in train_loader:
            batch_x = batch_x.to(device)
            recon, mu, logvar = model(
                batch_x,
                sample_latent=True,
                use_teacher_forcing=True,
            )
            loss, recon_loss, kld_loss = vae_loss(recon, batch_x, mu, logvar)

            optimizer.zero_grad()
            loss.backward()
            optimizer.step()

            total_loss += loss.item()
            total_recon += recon_loss.item()
            total_kld += kld_loss.item()
            num_batches += 1

        avg_loss = total_loss / num_batches
        avg_recon = total_recon / num_batches
        avg_kld = total_kld / num_batches

        loss_hist.append(avg_loss)
        recon_hist.append(avg_recon)
        kld_hist.append(avg_kld)

        if (epoch + 1) % 10 == 0:
            print(
                f"Epoch [{epoch + 1}/{num_epochs}] "
                f"Loss: {avg_loss:.6f} | Recon: {avg_recon:.6f} | KLD: {avg_kld:.6f}"
            )

    return loss_hist, recon_hist, kld_hist


def mc_reconstruct(
    model,
    waveform_norm,
    mc_samples=30,
    device="cpu",
    sample_latent=True,
    use_teacher_forcing=True,
):
    """Monte Carlo reconstruction for uncertainty estimation.

    waveform_norm shape: (seq_len,)
    returns:
    - mean: (seq_len,)
    - std: (seq_len,)
    """
    model.eval()
    x = waveform_norm.unsqueeze(0).unsqueeze(-1).to(device)

    preds = []
    with torch.no_grad():
        for _ in range(mc_samples):
            recon, _, _ = model(
                x,
                sample_latent=sample_latent,
                use_teacher_forcing=use_teacher_forcing,
            )
            preds.append(recon.squeeze(0).squeeze(-1).cpu())
    preds = torch.stack(preds, dim=0)
    return preds.mean(dim=0), preds.std(dim=0)


def plot_results(
    train_losses,
    recon_losses,
    kld_losses,
    noisy_waveform,
    recon_mean,
    recon_std,
    waveform_idx=0,
):
    epochs = np.arange(1, len(train_losses) + 1)

    fig1, ax1 = plt.subplots(1, 1, figsize=(6, 3.5))
    ax1.plot(epochs, train_losses, label="Total loss")
    ax1.plot(epochs, recon_losses, label="Reconstruction loss")
    ax1.plot(epochs, kld_losses, label="KLD")
    ax1.set_xlabel("Epoch")
    ax1.set_ylabel("Loss")
    ax1.legend()
    plt.tight_layout()
    plt.show()

    x_axis = np.arange(noisy_waveform.shape[0])
    print(
        "Reconstruction uncertainty std stats: "
        f"min={recon_std.min():.6f}, max={recon_std.max():.6f}, mean={recon_std.mean():.6f}"
    )
    fig2, ax2 = plt.subplots(1, 1, figsize=(8, 4))
    ax2.plot(x_axis, noisy_waveform, label="Noisy input", alpha=0.8)
    ax2.plot(x_axis, recon_mean, label="Reconstructed mean", linestyle="dashed")
    ax2.fill_between(
        x_axis,
        recon_mean - recon_std,
        recon_mean + recon_std,
        alpha=0.9,
        label="Reconstruction ±1 std",
    )
    ax2.set_title(f"Waveform {waveform_idx}")
    ax2.set_xlabel("Sample index")
    ax2.set_ylabel("Potential (mV)")
    ax2.legend()
    plt.tight_layout()
    plt.show()


def main():
    csv_path = "test_L44E.csv"
    max_examples = 100
    expected_length = 1600
    test_size = 0.2
    batch_size = 32
    num_epochs = 100
    hidden_dim = 64
    latent_dim = 8
    num_layers = 1
    learning_rate = 1e-3
    mc_samples = 30
    waveform_idx_to_plot = 0

    device = "cuda" if torch.cuda.is_available() else "cpu"
    print(f"Using device: {device}")

    waveforms = load_waveforms(
        csv_path=csv_path,
        max_examples=max_examples,
        expected_length=expected_length,
    )

    train_wf, test_wf = train_test_split(
        waveforms.numpy(),
        test_size=test_size,
        random_state=42,
        shuffle=True,
    )
    train_wf = torch.tensor(train_wf, dtype=torch.float32)
    test_wf = torch.tensor(test_wf, dtype=torch.float32)

    train_norm, test_norm, mean, std = normalize_train_test(train_wf, test_wf)

    train_x = train_norm.unsqueeze(-1)
    train_loader = DataLoader(
        TensorDataset(train_x),
        batch_size=batch_size,
        shuffle=True,
        drop_last=False,
    )

    seq_len = train_x.shape[1]
    model = LSTMVAE(
        seq_len=seq_len,
        n_features=1,
        hidden_dim=hidden_dim,
        latent_dim=latent_dim,
        num_layers=num_layers,
    ).to(device)
    optimizer = torch.optim.Adam(model.parameters(), lr=learning_rate)

    loss_hist, recon_hist, kld_hist = train_model(
        model=model,
        train_loader=train_loader,
        optimizer=optimizer,
        num_epochs=num_epochs,
        device=device,
    )

    if waveform_idx_to_plot < 0 or waveform_idx_to_plot >= len(test_norm):
        raise ValueError(
            f"waveform_idx_to_plot={waveform_idx_to_plot} out of range [0..{len(test_norm)-1}]"
        )

    noisy = test_wf[waveform_idx_to_plot]
    recon_mean_norm, recon_std_norm = mc_reconstruct(
        model,
        test_norm[waveform_idx_to_plot],
        mc_samples=mc_samples,
        device=device,
        sample_latent=True,
        use_teacher_forcing=True,
    )
    recon_mean = recon_mean_norm * std + mean
    recon_std = recon_std_norm * std

    plot_results(
        train_losses=loss_hist,
        recon_losses=recon_hist,
        kld_losses=kld_hist,
        noisy_waveform=noisy.cpu().numpy(),
        recon_mean=recon_mean.cpu().numpy(),
        recon_std=recon_std.cpu().numpy(),
        waveform_idx=waveform_idx_to_plot,
    )


if __name__ == "__main__":
    main()
