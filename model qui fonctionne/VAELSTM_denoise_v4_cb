def compute_paired_pvalues(all_outputs):
    """Paired Wilcoxon p-values for linear vs lstm (lower is better)."""
    if "linear" not in all_outputs or "lstm" not in all_outputs:
        return pd.DataFrame()

    def paired_wilcoxon(a, b, metric_name):
        a_np = np.asarray(a, dtype=float)
        b_np = np.asarray(b, dtype=float)
        valid = np.isfinite(a_np) & np.isfinite(b_np)
        a_np = a_np[valid]
        b_np = b_np[valid]
        row = {
            "metric": metric_name,
            "model_a": "linear",
            "model_b": "lstm",
            "alternative": "linear_less_than_lstm",
            "n_pairs": int(len(a_np)),
            "mean_diff_a_minus_b": float(np.mean(a_np - b_np)) if len(a_np) else np.nan,
            "median_diff_a_minus_b": (
                float(np.median(a_np - b_np)) if len(a_np) else np.nan
            ),
            "statistic": np.nan,
            "p_value": np.nan,
            "note": "",
        }
        if len(a_np) == 0:
            row["note"] = "No finite paired values."
            return row
        if wilcoxon is None:
            row["note"] = "scipy not available; p-value not computed."
            return row
        stat = wilcoxon(a_np, b_np, alternative="less", zero_method="wilcox")
        row["statistic"] = float(stat.statistic)
        row["p_value"] = float(stat.pvalue)
        return row

    linear_metrics = all_outputs["linear"]["metrics"]
    lstm_metrics = all_outputs["lstm"]["metrics"]
    rows = [
        paired_wilcoxon(
            linear_metrics["mae_per_waveform"].detach().cpu().numpy(),
            lstm_metrics["mae_per_waveform"].detach().cpu().numpy(),
            "mae_norm",
        ),
        paired_wilcoxon(
            linear_metrics["rmse_per_waveform"].detach().cpu().numpy(),
            lstm_metrics["rmse_per_waveform"].detach().cpu().numpy(),
            "rmse_norm",
        ),
        paired_wilcoxon(
            linear_metrics["n2n_per_example"],
            lstm_metrics["n2n_per_example"],
            "n2n_mse_norm_abs",
        ),
    ]
    return pd.DataFrame(rows)


