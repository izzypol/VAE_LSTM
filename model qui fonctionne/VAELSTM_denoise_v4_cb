def load_waveforms(csv_path, max_examples=100):
    """
    Function thatextracts the data from the csv and formats them for training 

    Arguments: 
    - csv_path: relative path that leads to the csv containing the data
    - max_examples: sets limit of number of curves to load because it quickly becomes very time intensive 

    Returns: 
    - tensor containing the formatted data 
    - WHAT IS THE METADATA???
    """

    data = pd.read_csv(csv_path).transpose().values
    if max_examples is not None:
        data = data[:max_examples]
    decay_1 = data[:, 415:785]
    decay_2 = data[:, 1215:1585]
    stacked = np.concatenate([decay_1, decay_2], axis=0)
    metadata = np.concatenate( # WHAT IS THE METADATA???? info qui permet de reconstruire la pseudosection
        [
            np.column_stack(
                [
                    np.arange(decay_1.shape[0], dtype=int),
                    np.zeros(decay_1.shape[0], dtype=int),
                ]
            ),
            np.column_stack(
                [
                    np.arange(decay_2.shape[0], dtype=int),
                    np.ones(decay_2.shape[0], dtype=int),
                ]
            ),
        ],
        axis=0,
    )
    return torch.tensor(stacked, dtype=torch.float32), metadata


def minmax_scale_per_waveform(waveforms):
    """
    Function that calculates the min and max of the waveforms and also scales them

    Arguments: 
    - waveforms: the signals (num_examples, signal length)

    Returns: 
    - wf_min: the min of the waveform
    - wf_max: the max of the waveform
    - scaled: the scaled waveform

    """

    # waveforms: (num_examples, signal_len)
    wf_min = waveforms.min(dim=1, keepdim=True).values
    wf_max = waveforms.max(dim=1, keepdim=True).values
    # normalisation
    wf_range = (wf_max - wf_min).clamp_min(1e-6) # WHAT DOES THIS DOOOOOOO
    scaled = (waveforms - wf_min) / wf_range # WHAT DOES THIS DOOOOOOO
    # normalisation entre 0 et 1 et garde les min et max pour défaire la norma
    return scaled, wf_min, wf_max


class WindowVAE(nn.Module):
    """
    Structure of two models: 
    - LSTM based VAE: uses LSTM layers for both encoder and decoder, with linear layers to map to/from the latent space.
    - Linear VAE: uses fully connected layers for both encoder and decoder, with linear layers to map to/from the latent space.
    """
    def __init__(
        self,
        signal_length=100, # default values for the model's structure and hyperparameters 
        hidden_dim=64,
        latent_dim=8,
        num_layers=1,
        model_type="lstm",
    ):
        # by default its LSTM 
        super().__init__()
        self.signal_length = signal_length
        self.hidden_dim = hidden_dim
        self.latent_dim = latent_dim
        self.num_layers = num_layers
        self.model_type = model_type

        if self.model_type == "lstm":
            # encoder: LSTM layers followed by linear layers to get mu and logvar
            self.encoder = nn.LSTM(
                input_size=1, 
                hidden_size=hidden_dim,
                num_layers=num_layers,
                batch_first=True,
            )
            self.to_mu = nn.Linear(hidden_dim, latent_dim)
            self.to_logvar = nn.Linear(hidden_dim, latent_dim)

            # map the latent vector to the hidden state of the decoder
            self.latent_to_hidden = nn.Linear(latent_dim, hidden_dim)
            self.latent_to_input = nn.Linear(latent_dim, 1)
            # decoder: LSTM layers followed by a linear layer to get the output features
            self.decoder = nn.LSTM(
                input_size=1,
                hidden_size=hidden_dim,
                num_layers=num_layers,
                batch_first=True,
            )
            self.to_output = nn.Linear(hidden_dim, 1)
        elif self.model_type == "linear":
            # fully connected non-lstm option 
            encoder_layers = [nn.Linear(signal_length, hidden_dim), nn.SiLU()]
            for _ in range(max(0, num_layers - 1)):
                encoder_layers.extend([nn.Linear(hidden_dim, hidden_dim), nn.SiLU()])
            self.encoder_mlp = nn.Sequential(*encoder_layers)
            self.to_mu = nn.Linear(hidden_dim, latent_dim)
            self.to_logvar = nn.Linear(hidden_dim, latent_dim)

            decoder_layers = [nn.Linear(latent_dim, hidden_dim), nn.SiLU()]
            for _ in range(max(0, num_layers - 1)):
                decoder_layers.extend([nn.Linear(hidden_dim, hidden_dim), nn.SiLU()])
            decoder_layers.append(nn.Linear(hidden_dim, signal_length))
            self.decoder_mlp = nn.Sequential(*decoder_layers)
        else:
            # what to do if model_type is not recognized
            raise ValueError(
                f"Unsupported model_type={self.model_type}. Use 'lstm' or 'linear'."
            )

    def encode(self, x):
        """
        Function that does the steps and calculations for the encoder section  

        Arguments: 
        - self: the model
        - x: the input data (B, signal length, 1)

        Returns: 
        - mu: the mean vector 
        - logvar: the log variance vector
        """
        # x: (B, signal_length, 1)
        if self.model_type == "lstm":
            _, (h_n, _) = self.encoder(x) # get the hidden state
            h_last = h_n[-1] # get the hidden state of the last layer
        else: # for the non-lstm model
            x_flat = x.squeeze(-1)
            h_last = self.encoder_mlp(x_flat)
        
        # calculate the mean and the logarithm of the variance (latent space variables)
        mu = self.to_mu(h_last)
        logvar = self.to_logvar(h_last)
        return mu, logvar

    def reparameterize(self, mu, logvar):
        """
        Function that does the reparametrization trick 

        Arguments: 
        - self: the model
        - mu: the mean vector from the encoder
        - logvar: the log variance vector from the encoder

        Returns: 
        - reparamed vector
        """
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        return mu + eps * std

    def decode(self, z):
        """ function that does the steps and calculations for the encoder section
        
        Arguments: 
        - self: the model
        - z: the input form the latent space

        Returns: 
        - out: the reconstructed output data 
        
        """

        if self.model_type == "lstm":
            h0 = self.latent_to_hidden(z).unsqueeze(0).repeat(self.num_layers, 1, 1)
            c0 = torch.zeros_like(h0)
            latent_step = self.latent_to_input(z).unsqueeze(1)
            dec_input = latent_step.repeat(1, self.signal_length, 1)
            dec_out, _ = self.decoder(dec_input, (h0, c0))
            return self.to_output(dec_out)
        # section just for the non-lstm model
        out = self.decoder_mlp(z) 
        return out.unsqueeze(-1)

    def forward(self, x, sample_latent=True):
        """
        Function that allows the code to go through the layers of model

        Arguments: 
        - self: the model
        - x: the input data 
        - sample latent: si on voulait déterministe, on ferait false et on ferait pas le reparam trick (donne la moyenne)

        Returns: 
        - recon: the reconstructed output data 
        - mu: the mean vector 
        - logvar: the logarithm variance vector
        """
        mu, logvar = self.encode(x)
        z = self.reparameterize(mu, logvar) if sample_latent else mu
        recon = self.decode(z)
        return recon, mu, logvar


def softclip(x, min_value):
    """
    Function that clips the tensor values at the minimum value in a softway (source: sigma-vae-pytorch by orybkin, Handful of Trials)

    Arguments: 
    - x: input data
    - min_value: the minimum value ot consider 

    Returns: 
    - the softclip 
    """
    return min_value + F.softplus(x - min_value)


def gaussian_nll(recon, log_sigma, target):
    """
    Function that calculates the gaussian negative log likelyhood 

    Arguments:
    - recon: the reconstructed data 
    - log_sigma: the standard deviation 
    - target: 

    Returns: 
    - the gaussian negative loss likelyhood 
    """
    const = 0.5 * torch.log(torch.tensor(2.0 * np.pi, device=target.device))
    return 0.5 * ((target - recon) / log_sigma.exp()) ** 2 + log_sigma + const


def vae_loss(recon, x, mu, logvar, min_log_sigma=-6.0):
    """ 
    Function that calculates the loss for the model (includes the gaussian nnl, the reconstruction loss, and the Kullback-Liebler divergence)

    Arguments: 
    - recon: the reconstructed data
    - x: the input data 
    - mu: the mean vector 
    - logvar: the logarithm variance vector 
    - min_log_sigma: the minimum for log_sigma 

    Returns: 
    - total: the combination of the reconstruction loss and the kld 
    - recon_loss: the reconstruction loss 
    - kld: the Kullback-Liebler divergence 
    """
    raw_log_sigma = ((x - recon) ** 2).mean().sqrt().log()
    log_sigma = softclip(raw_log_sigma, min_log_sigma)
    recon_loss = gaussian_nll(recon, log_sigma, x).sum(dim=(1, 2)).mean()
    kld = -0.5 * torch.mean(torch.sum(1 + logvar - mu.pow(2) - logvar.exp(), dim=1))
    total = recon_loss + kld
    return total, recon_loss, kld


def train_model(model, loader, optimizer, num_epochs=120, device="cpu"):
    """
    Function that does the training of the model 

    Arguments: 
    - model: the model
    - loader: what
    - optimizer: the function used for the optimization 
    - num_epochs: the number of epochs (number of times the calculations are repeated), by default 120
    - device: where the calculations are done in the computer 

    Returns: 
    - hist_total: list containing the mean total loss values 
    - hist_recon: list contining the mean reconstruction loss values 
    - hist_kld: list containing the mean kld values 
    """

    hist_total, hist_recon, hist_kld = [], [], []
    model.train() # put in training mode 
    for epoch in range(num_epochs): # cycle through the epochs 
        tot, rec, kld = 0.0, 0.0, 0.0 # initialise 
        n = 0
        for (xb,) in loader:
            xb = xb.to(device)
            recon, mu, logvar = model(xb, sample_latent=True)
            loss, recon_loss, kld_loss = vae_loss(recon, xb, mu, logvar)

            optimizer.zero_grad()
            loss.backward()
            optimizer.step()

            tot += loss.item()
            rec += recon_loss.item()
            kld += kld_loss.item()
            n += 1

        # only append the average value and not the raw value (too much variation in teh values)
        hist_total.append(tot / n) 
        hist_recon.append(rec / n)
        hist_kld.append(kld / n)

        if (epoch + 1) % 10 == 0:
            print(
                f"Epoch [{epoch+1}/{num_epochs}] "
                f"Loss: {hist_total[-1]:.5f} | Recon: {hist_recon[-1]:.5f} | KLD: {hist_kld[-1]:.5f}"
            )
    return hist_total, hist_recon, hist_kld


def mc_reconstruct_waveform(
    model,
    waveform_norm,
    mc_samples=30,
    device="cpu",
    return_samples=False,
):
    
    """
    Function that reconstructs the waveform from the eval step 

    Arguments:
    - model: the model 
    - waveform_norm: normalised waveforms
    - mc samples: by default 30
    - return_samples: weather or not to return the reconstructed sample list without averaging 

    Returns: 
    - all_recons.mean: the averaged list of the reconstructed values 
    - all_recons.std: the standard deviation of the reconstructed values 
    """
    # waveform_norm: (signal_len,)
    x = waveform_norm.unsqueeze(0).unsqueeze(-1).to(device)  # (1, signal_len, 1)

    all_recons = []
    # put in evaluation mode 
    model.eval()
    with torch.no_grad():
        for _ in range(mc_samples):
            recon, _, _ = model(x, sample_latent=True) # calulate the reconstructed values 
            recon_wave = recon.squeeze(0).squeeze(-1).cpu()  # (signal_len,)
            all_recons.append(recon_wave)

    all_recons = torch.stack(all_recons, dim=0)  # (mc_samples, signal_len)
    if return_samples:
        return all_recons.mean(dim=0), all_recons.std(dim=0), all_recons
    return all_recons.mean(dim=0), all_recons.std(dim=0)


def plot_training_losses(loss_total, loss_recon, loss_kld):
    """
    Function that plots the evolution of the loss throughout the training 

    Arguments: 
    - loss_total: list containing the total loss values 
    - loss_recon: list containing the reconstruction loss values 
    - loss_kld: list containing the kld values 

    Returns: 
    - nothing but displays a graph showing the evolution of the three loss values in function of the epochs
    """

    epochs = np.arange(1, len(loss_total) + 1)
    fig1, ax1 = plt.subplots(1, 1, figsize=(6, 3.5))
    ax1.plot(epochs, loss_total, label="Total")
    ax1.plot(epochs, loss_recon, label="Recon")
    ax1.plot(epochs, loss_kld, label="KLD")
    ax1.set_xlabel("Epoch")
    ax1.set_ylabel("Loss")
    ax1.legend()
    plt.tight_layout()
    plt.show()


def plot_reconstruction_with_uncertainty(
    noisy,
    recon_mean,
    recon_std,
    ci_lower=None, # what are these 
    ci_upper=None,
):
    
    """
    Function that plots the reconstructed values and their uncertainty 

    Arguments: 
    - noisy: the raw data
    - recon_mean: the average of the recontructed values 
    - recon_std: the standard deviation of the reconstructed values
    - ci_lower/upper: (confidence intervale) si on connait les erreur de constru on peut les passer mais mieux de les calculer
    """
    fig2, ax2 = plt.subplots(1, 1, figsize=(8, 4))
    x = np.arange(noisy.shape[0])
    ax2.plot(x, noisy, ".k", label="Noisy input", alpha=0.85)
    ax2.plot(x, recon_mean, label="Reconstructed mean", linestyle="-")
    if ci_lower is not None and ci_upper is not None:
        ax2.fill_between(
            x,
            ci_lower,
            ci_upper,
            alpha=0.2,
            label="95% CI",
        )
    else:
        ci95 = 1.96 * recon_std
        ax2.fill_between(
            x,
            recon_mean - ci95,
            recon_mean + ci95,
            alpha=0.2,
            label="95% CI",
        )
    ax2.set_xlabel("Sample index")
    ax2.set_ylabel("Potential (mV)")
    ax2.legend()
    plt.tight_layout()
    plt.show()


