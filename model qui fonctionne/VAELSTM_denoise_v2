def prep_data(file_name):

    """ function that prepares the data in a format that is compatible with the model

    Arguments: 
    - file_name: name of the csv containing the full waveform data

    Returns: 
    - train_vstack: tensor containing the training data 
    - test_vstack: tensor containing the test data 
    """
    # extract data 
    df = pd.read_csv(file_name).transpose().values[:1] # change the number later

    # add spike later for testing 

    # separate into train and test datasets 
    # train__vstack, test_vstack = train_test_split(df, test_size=0.8)
    train__vstack, test_vstack = df, df
    train_size = len(train__vstack)
    test_size = len(test_vstack)

    # size of the sliding window
    lookback = 1600 

    # create a new tensor that uses the size of the sliding window
    # and has overlapping windows 
    train_vstack = view_as_windows(train__vstack, (1, lookback), step=(1,1)).reshape(-1, lookback)
    test_vstack = view_as_windows(test_vstack, (1, lookback), step=(1,1)).reshape(-1, lookback)

    # convert to pytorch tensor
    train_vstack = torch.tensor(train_vstack).float()
    test_vstack = torch.tensor(test_vstack).float()

    return train_vstack, test_vstack

# Define the LSTM-based Variational Autoencoder (VAE) model
class LSTMVAE(nn.Module):
    def __init__(self, seq_len, n_features, hidden_dim, latent_dim, num_layers=1):
        super(LSTMVAE, self).__init__()
        self.seq_len = seq_len
        self.n_features = n_features
        self.hidden_dim = hidden_dim
        self.latent_dim = latent_dim
        self.num_layers = num_layers
        self.log_logma = torch.zeros([])

        # encoder
        self.encoder_lstm = nn.LSTM(
            input_size=n_features,
            hidden_size=hidden_dim,
            num_layers=num_layers,
            batch_first=True,
        )
        self.hidden2mu = nn.Linear(hidden_dim, latent_dim)
        self.hidden2logvar = nn.Linear(hidden_dim, latent_dim)

        # decoder
        self.latent2hidden = nn.Linear(latent_dim, hidden_dim)
        self.decoder_lstm = nn.LSTM(
            input_size=n_features,
            hidden_size=hidden_dim,
            num_layers=num_layers,
            batch_first=True,
        )
        self.outputs2features = nn.Linear(hidden_dim, n_features)

    def encode(self, x):
        _, (h_n, _) = self.encoder_lstm(x)
        h = h_n[-1]  # last layer's hidden state
        mu = self.hidden2mu(h)
        logvar = self.hidden2logvar(h)
        return mu, logvar

    def reparameterize(self, mu, logvar):
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        return mu + eps * std

    def decode(self, z):
        # check this
        # initialize hidden and cell states from latent vector
        h0 = self.latent2hidden(z).unsqueeze(0).repeat(self.num_layers, 1, 1)
        c0 = torch.zeros_like(h0)
        # feed zero input sequence to the decoder
        dec_input = torch.zeros(z.size(0), self.seq_len, self.n_features, device=z.device)
        dec_output, _ = self.decoder_lstm(dec_input, (h0, c0))
        out = self.outputs2features(dec_output)
        return out

    def forward(self, x):
        mu, logvar = self.encode(x)
        z = self.reparameterize(mu, logvar)
        recon = self.decode(z)

        # calc loss
        loss, recon_loss, kld_loss = self.loss_fct(recon, x, mu, logvar)
        return recon, loss, recon_loss, kld_loss, mu, logvar
    
    def gaussian_nnl(self, mu, log_sigma, input): 
        return 0.5*torch.pow((input-mu) / log_sigma.exp(), 2) + log_sigma+ 0.5 * torch.tensor(2*np.pi).log()
    
    def softclip(self, input, min):
        result_tensor = min + F.softplus(input - min)
        return result_tensor
    
    def loss_fct(self, *args):
        recon_loss = args[0]
        input = args[1]
        mu = args[2]
        logvar = args[3]

        # recon loss part
        self.log_sigma = ((input - recon_loss) ** 2).mean().sqrt().log() 
        log_sigma = self.softclip(self.log_sigma, -6)
        recons_loss = self.gaussian_nnl(recon_loss, log_sigma, input).sum()

        # kld loss part
        kld_loss = -0.5 * torch.sum(1 + logvar - mu.pow(2) - logvar.exp())

        # total loss
        loss = recons_loss + kld_loss

        return loss, recons_loss, kld_loss

# Model, loss function, and optimizer
# reshape data for LSTM (batch, seq_len, features)

train_data, test_data = prep_data('test_L44E.csv')
train_vstack = train_data.unsqueeze(-1)
test_vstack = test_data.unsqueeze(-1)

seq_len = train_vstack.size(1)
n_features = 1
hidden_dim = 64 # do we make this 100 to correspond to the lookback 
latent_dim = 2 # faire varier pcq ca peut faire stagner le model
model = LSTMVAE(seq_len, n_features, hidden_dim, latent_dim)
optimizer = torch.optim.Adam(model.parameters(), lr=0.001)

# training hyperparameters
num_epochs = 500
batch_size = 32

# save the values of loss, recon loss and kls loss for a graph later
loss_tot = []
recon_tot = []
kld_tot = []

# Step 3: Train the LSTM VAE
for epoch in range(num_epochs):
    total_loss = 0
    num_batches = 0
    for i in range(0, len(train_vstack), batch_size):
        batch_vstack = train_vstack[i:i+batch_size]

        recon, loss, recon_loss, kld_loss, mu, logvar = model(batch_vstack)
        loss_tot.append(loss.item())
        recon_tot.append(recon_loss.item()) # append le loss moyen au lieu du loss brute comme ici
        kld_tot.append(kld_loss.item())

        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        total_loss += loss.item()
        num_batches += 1

    if (epoch+1) % 10 == 0:
        avg_loss = total_loss / num_batches
        print(f'Epoch [{epoch+1}/{num_epochs}], Loss: {avg_loss:.4f}')

# Step 4: Visualize Results
def visualize_results(model, file_name):
    """Function that evaluates the model suing the test dataset and visualises the results 
       and the evolution of the loss values 

    Arguments: 
    - model: the trained LSTM VAE model
    - file_name: the name of the csv containing the full waveform data

    returns:
    - graph 1: comparisson between raw and denoised curves 
    - curve 2: evolution of the loss values during training
    """

    # extract the data 
    _, test_vstack = prep_data(file_name)

    # combine the curves for the raw data
    noisy = torch.empty((1501,1600), dtype=torch.float32)
    noisy[:] = np.nan
    starting_places1 = 0
    stoping_places1 = 100
    row = 0
    for l in noisy:
        if starting_places1 <= 1500: 
            l[starting_places1:stoping_places1] = test_vstack[row]
            starting_places1 += 1
            stoping_places1 += 1
            row += 1
        else: 
            continue
    noisy = noisy.nanmean(0)
    
    model.eval()
    # evaluate and combine the curves for the denoised data
    with torch.no_grad():
        pred = torch.empty((1501,1600), dtype=torch.float32)
        pred[:] = np.nan
        starting_places = 0
        stoping_places = 100
        reconstructed, _, _, _, _, _ = model(test_vstack.unsqueeze(-1))
        for i, j in zip(pred, reconstructed):
            if starting_places <= 1500: 
                i[starting_places:stoping_places] = j.squeeze(-1) # add other dimension pour toutes les courbes 
                starting_places += 1
                stoping_places += 1
